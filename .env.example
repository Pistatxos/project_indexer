# Ajustes de project_index.py.
# Copia este archivo a ".env" en la misma carpeta y edítalo con tus rutas.
#
#   cp .env.example .env
#
# El ".env" NO se sube a git (está en .gitignore): así tus ajustes del NAS
# sobreviven cuando actualizas el script (lo sobrescribes sin perder la config).
#
# Precedencia: argumentos de CLI  >  .env  >  valores por defecto del script.

# Raíces a escanear (categoria/proyecto). Varias separadas por comas. Admiten "~".
#   local: ROOTS=~/projects
#   NAS  : ROOTS=/volume1/Developer
ROOTS=~/projects

# README a actualizar entre marcadores. Vacío (README=) = imprime por consola.
README=~/projects/README.md

# Carpetas extra a excluir (nombres exactos o globs), separadas por comas.
# Se suman a las que ya se ignoran siempre (.git, node_modules, @eaDir, …).
EXCLUDE=

# Zona horaria de la fecha de actualización.
TIMEZONE=Europe/Madrid

# Crear un .project.yml plantilla en las carpetas que no tengan (true/false).
INIT=true
